# ===========================================
# 技术脉动 Blog - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ===========================================

# --- Server ---
SERVER_PORT=8080

# --- MySQL ---
DB_URL=jdbc:mysql://localhost:3306/blog_db?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=123456

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_ENABLED=false

# --- JWT ---
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- AI (通义千问 DashScope) ---
AI_API_KEY=sk-your-api-key-here
